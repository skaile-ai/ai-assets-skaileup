{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "flow.schema.json",
  "title": "ConceptForge Flow",
  "description": "A skill pipeline flow definition. Node/edge structure is compatible with Vue Flow (@vue-flow/core) and React Flow (@xyflow/react). Each flow file is self-contained: skill metadata (writes, requires, user_inputs, feedback, grounding_folder) lives on each node. Skills are referenced by canonical name only — never by path. See skaileup-shared/contracts/flows.md for authoring guidance.",
  "type": "object",
  "required": ["id", "name", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },

    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique flow identifier, kebab-case. Matches the filename without .json."
    },

    "version": { "type": "string", "default": "1.0" },
    "name": { "type": "string" },
    "description": { "type": "string" },

    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "icon": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["full-stack", "prototype", "concept", "cli", "maintenance", "incremental"]
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "onboarding": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "input_style": { "type": "string", "enum": ["freeform", "structured", "repo"] },
            "placeholder": { "type": "string" },
            "fields": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "globals": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "research_depth": { "type": "string", "enum": ["skip", "light", "moderate", "deep"] },
        "approval_mode": { "type": "string", "enum": ["checkpoint", "auto_approve"] },
        "auto_review": { "type": "boolean" },
        "subagent_mode": { "type": "boolean" },
        "verbosity": { "type": "string", "enum": ["brief", "standard", "detailed"] }
      }
    },

    "modes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "research": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "skill": { "type": "string", "description": "Canonical skill name, e.g. 'research'" },
            "triggers": { "type": "array", "items": { "type": "string" } },
            "parameters": { "type": "object", "additionalProperties": true }
          }
        },
        "standards": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "skill": {
              "type": "string",
              "description": "Canonical skill name, e.g. 'standards-discover'"
            },
            "inject_skill": {
              "type": "string",
              "description": "Canonical skill name, e.g. 'standards-inject'"
            },
            "trigger_after": { "type": "string" },
            "parameters": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },

    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [{ "$ref": "#/$defs/skill-node" }, { "$ref": "#/$defs/group-node" }]
      }
    },

    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/flow-edge" }
    },

    "entry": { "type": "string" },

    "next_flows": {
      "type": "array",
      "description": "Suggested flows to run after this one completes. Shown as hints in the UI at flow completion.",
      "items": {
        "type": "object",
        "required": ["id", "domain"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Flow file ID (without .json), e.g. 'standard'"
          },
          "domain": {
            "type": "string",
            "enum": ["skaileup-conceptualization", "skaileup-implementation", "skaileup-evaluate"],
            "description": "Domain folder containing the flow"
          },
          "label": {
            "type": "string",
            "description": "Short action label shown in UI, e.g. 'Implement →'"
          },
          "hint": {
            "type": "string",
            "description": "One-sentence description of what the next flow does"
          }
        }
      }
    }
  },

  "$defs": {
    "skill-node": {
      "type": "object",
      "required": ["id", "type", "position", "data"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "const": "skill" },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
        },
        "parentNode": { "type": "string" },
        "data": {
          "type": "object",
          "required": ["skill"],
          "additionalProperties": false,
          "properties": {
            "skill": {
              "type": "string",
              "description": "Canonical skill name (kebab-case, matches `name` in SKILL.md frontmatter). e.g. 'overview', 'datamodel', 'scaffold'. Never a file path."
            },
            "label": { "type": "string" },
            "optional": { "type": "boolean", "default": false },
            "parallel_group": { "type": "string" },
            "subagent": { "type": "boolean" },
            "writes": {
              "type": ["string", "null"],
              "description": "_concept/ subfolder this skill writes to, e.g. '1_discovery/1_overview/'. Null for implementation skills that write to project code."
            },
            "requires": {
              "type": "array",
              "items": { "type": "string" },
              "description": "_concept/ paths that must exist before this skill runs."
            },
            "grounding_folder": {
              "type": "string",
              "description": "Subfolder within _grounding/ for this skill's research and user_input.json."
            },
            "user_inputs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "dialog": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "label", "type"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string" },
                      "label": { "type": "string" },
                      "type": {
                        "type": "string",
                        "enum": ["text", "textarea", "select", "multiselect", "boolean", "number"]
                      },
                      "required": { "type": "boolean", "default": false },
                      "options": { "type": "array", "items": { "type": "string" } },
                      "default": {},
                      "hint": { "type": "string" }
                    }
                  }
                },
                "files": { "type": "array", "items": { "type": "string" } }
              }
            },
            "feedback": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["updates", "field"],
                "additionalProperties": false,
                "properties": {
                  "updates": { "type": "string" },
                  "field": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            },
            "parameters": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },

    "group-node": {
      "type": "object",
      "required": ["id", "type", "position", "data"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "const": "group" },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
        },
        "style": { "type": "object", "additionalProperties": true },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "label": { "type": "string" }, "phase": { "type": "string" } }
        }
      }
    },

    "flow-edge": {
      "type": "object",
      "required": ["id", "source", "target"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "sourceHandle": { "type": "string" },
        "targetHandle": { "type": "string" },
        "type": { "type": "string", "enum": ["flow", "optional", "parallel"], "default": "flow" },
        "animated": { "type": "boolean", "default": false },
        "label": { "type": "string" },
        "data": {
          "type": "object",
          "additionalProperties": true,
          "properties": { "condition": { "type": "string" } }
        }
      }
    }
  }
}
