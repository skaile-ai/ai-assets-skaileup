{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saxe.dev/schemas/stories/v1",
  "title": "SAXE Stories",
  "description": "Schema for _concept/2_experience/1_journeys/stories.json — personas, story maps, and EARS acceptance criteria produced by the concept-2-experience-1-journeys skill.",
  "type": "object",
  "required": ["version", "concept", "personas", "story_maps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version. Always \"1.0\" for this draft."
    },
    "concept": {
      "type": "object",
      "description": "High-level context extracted from the project brief.",
      "required": ["name", "problem", "success_metrics"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "App name from brief.md."
        },
        "problem": {
          "type": "string",
          "minLength": 1,
          "description": "Problem statement from brief.md."
        },
        "success_metrics": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Measurable success criteria from goals.md."
        }
      }
    },
    "personas": {
      "type": "array",
      "minItems": 1,
      "description": "User personas derived from the brief audience and optional research.",
      "items": {
        "$ref": "#/$defs/persona"
      }
    },
    "story_maps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of story maps. Exactly one must have stage \"hero\".",
      "items": {
        "$ref": "#/$defs/story_map"
      }
    }
  },
  "$defs": {
    "persona": {
      "type": "object",
      "required": ["id", "label", "goals"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Slug identifier (e.g. \"ops-manager\")."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name (e.g. \"Operations Manager\")."
        },
        "goals": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "What this persona wants to achieve with the app."
        }
      }
    },
    "story_map": {
      "type": "object",
      "required": ["id", "label", "stage", "stories"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^journey-[0-9]{3}$",
          "description": "Journey identifier (e.g. \"journey-001\")."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Short descriptive name for the journey (e.g. \"Create and deploy a new app\")."
        },
        "stage": {
          "type": "string",
          "enum": ["hero", "vital", "hygiene", "backlog"],
          "description": "Journey priority stage. Exactly one story map must be \"hero\"."
        },
        "stories": {
          "type": "array",
          "minItems": 1,
          "description": "Ordered list of stories within this journey.",
          "items": {
            "$ref": "#/$defs/story"
          }
        }
      }
    },
    "story": {
      "type": "object",
      "required": [
        "id",
        "title",
        "persona",
        "outcome",
        "priority",
        "status",
        "acceptance_criteria",
        "review",
        "downstream"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^story-[0-9]{3}$",
          "description": "Unique story identifier (e.g. \"story-001\")."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Short action phrase describing what the user does."
        },
        "persona": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "References a persona id from the personas array."
        },
        "outcome": {
          "type": "string",
          "minLength": 1,
          "description": "What the user achieves when this story is complete."
        },
        "priority": {
          "type": "string",
          "enum": ["must", "should", "could", "wont"],
          "description": "MoSCoW priority. Hero stories are always \"must\"."
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "approved", "implemented", "tested"],
          "description": "Lifecycle status of the story."
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "description": "EARS or Gherkin acceptance criteria. At least one required.",
          "items": {
            "$ref": "#/$defs/acceptance_criterion"
          }
        },
        "review": {
          "type": "object",
          "required": ["mode"],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["auto_approve", "human_review"],
              "description": "Whether this story requires human review or can be auto-approved."
            }
          }
        },
        "downstream": {
          "type": "object",
          "required": ["candidate_features", "candidate_entities", "candidate_screens"],
          "additionalProperties": false,
          "description": "Hints for downstream skills (features, data model, screens).",
          "properties": {
            "candidate_features": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Feature names this story is likely to produce."
            },
            "candidate_entities": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Data entities this story is likely to touch."
            },
            "candidate_screens": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Screen names this story is likely to need."
            }
          }
        },
        "gherkin_scenarios": {
          "type": "array",
          "description": "Optional Gherkin scenarios for complex stories.",
          "items": {
            "$ref": "#/$defs/gherkin_scenario"
          }
        }
      }
    },
    "acceptance_criterion": {
      "type": "object",
      "required": ["kind", "text"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["ears", "gherkin"],
          "description": "Format of the criterion text."
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "The acceptance criterion statement (EARS pattern or Gherkin step)."
        }
      }
    },
    "gherkin_scenario": {
      "type": "object",
      "required": ["name", "steps"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Scenario title."
        },
        "steps": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Gherkin steps (Given/When/Then lines)."
        }
      }
    }
  }
}
