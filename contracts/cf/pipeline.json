  "feedback_loops": [
    {
      "from": "concept/experience/screens",
      "to": "concept/experience/features",
      "field": "screens",
      "description": "Screen skill registers itself in feature frontmatter"
    },
    {
      "from": "concept/blueprint/datamodel",
      "to": "concept/experience/features",
      "field": "data_entities",
      "description": "Datamodel skill sets data_entities in feature frontmatter"
    }
  ],
  "config": {
    "orchestrator_skill": "concept/orchestrator",
    "standalone_mode": {
      "enabled": true,
      "description": "Skills run independently, checking own hard_gates. Orchestrator suggests next steps after completion."
    },
    "standards_mode": {
      "skill": "standards/discover",
      "output_folder": "_standards/",
      "parallel": true,
      "description": "Discovers codebase conventions and writes them to _concept/_standards/"
    },
    "standards_injection": {
      "skill": "standards/inject",
      "description": "Matches discovered standards to requesting skill by applies_to + keyword overlap"
    },
    "profiles_file": "shared/contracts/profiles.json",
    "grounding_mode": {
      "skill": "concept/discovery/research",
      "output_folder": "_grounding/",
      "deprecated_folder": "_research/",
      "parallel": true,
      "description": "Research and grounding material for the concept. Step subfolders store per-step research, user_input.json, and context files.",
      "hidden_from_sidebar": ["_grounding", "_research"],
      "sub_folders": ["general/", "findings/"],
      "general_topics": [
        "domain",
        "competitors",
        "audiences",
        "design_inspiration",
        "patterns",
        "colors_fonts",
        "behavioral_patterns"
      ],
      "step_folders": {
        "concept/discovery/overview": "overview/",
        "concept/reverse-engineer": "reverse_engineer/",
        "concept/experience/features": "features/",
        "concept/experience/behaviors": "behaviors/",
        "concept/discovery/brand-visual": "brand_visual/",
        "concept/discovery/brand-behavioral": "brand_behavioral/",
        "concept/blueprint/techstack": "techstack/",
        "concept/blueprint/architecture": "architecture/",
        "concept/blueprint/datamodel": "datamodel/",
        "concept/experience/screens": "screens/",
        "concept/experience/components": "components/",
        "concept/experience/journeys": "journeys/",
        "concept/experience/storybook": "storybook/",
        "implement/foundation": "foundation/",
        "implement/design": "design/"
      }
    },
    "note": "This file is the skill catalog: hard_gates, user_inputs, folders, and phase taxonomy per skill. Flow sequencing, parameters, and execution order are defined in flows/*.json. Tech-stack-specific implementation details are in tech-stack/*.json.",
    "flows_dir": "flows/",
    "tech_stack_dir": "tech-stack/",
    "flow_schema": "flows/flow.schema.json"
  },
  "incremental_note": "Incremental flows (add-feature, etc.) are defined in flows/ as separate flow files."
}
