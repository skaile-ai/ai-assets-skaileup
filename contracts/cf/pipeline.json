{
  "version": "2.0",
  "phases": {
    "conceptualization": {
      "name": "Conceptualization",
      "description": "Full concept pipeline from brief to screen specs",
      "order": 1,
      "sub_phases": {
        "overall-concept": {
          "name": "Overall Concept",
          "order": 1
        },
        "functionality": {
          "name": "Functionality",
          "order": 2
        },
        "brand": {
          "name": "Brand & Identity",
          "order": 3
        },
        "techstack": {
          "name": "Tech Stack",
          "order": 4
        },
        "datamodel": {
          "name": "Data Model",
          "order": 5
        },
        "architecture": {
          "name": "System Architecture",
          "order": 6
        },
        "ui-planning": {
          "name": "UI Planning",
          "order": 7
        }
      }
    },
    "implementation": {
      "name": "Implementation",
      "description": "Building the app from concept artifacts",
      "order": 2,
      "sub_phases": {
        "bootstrap": {
          "name": "Bootstrap",
          "order": 1
        },
        "build": {
          "name": "Build",
          "order": 2
        }
      }
    },
    "testing": {
      "name": "Testing",
      "description": "Test generation and execution",
      "order": 3
    },
    "quality": {
      "name": "Quality",
      "description": "Audits, reviews, cross-reference repair, and readiness gates",
      "order": 4
    }
  },
  "steps": [
    {
      "id": "concept/reverse-engineer",
      "name": "Reverse Engineer from Repository",
      "skill": "concept/reverse-engineer",
      "phase": "conceptualization",
      "sub_phase": "overall-concept",
      "folder": "_concept/",
      "hard_gates": [],
      "user_inputs": {
        "dialog": [
          {
            "id": "repo_path",
            "label": "Repository Path",
            "type": "text",
            "required": true
          },
          {
            "id": "concept_path",
            "label": "Concept Output Path",
            "type": "text",
            "required": false
          },
          {
            "id": "extraction_scope",
            "label": "What to Extract",
            "type": "multiselect",
            "options": ["overview", "techstack", "features", "datamodel", "brand", "screens"],
            "default": ["overview", "techstack", "features", "datamodel", "brand", "screens"],
            "required": false
          },
          {
            "id": "overwrite_mode",
            "label": "Existing Files",
            "type": "select",
            "options": ["skip", "diff_and_confirm", "overwrite"],
            "default": "skip",
            "required": false
          },
          {
            "id": "app_description_hint",
            "label": "App Description Hint",
            "type": "text",
            "required": false
          }
        ],
        "files": []
      },
      "description": "Generates full _concept/ from an existing repository: overview, techstack, features, datamodel, brand, screens",
      "ui": {
        "show_in_sidebar": false
      }
    },
    {
      "id": "concept/discovery/overview",
      "name": "Project Overview",
      "skill": "concept/discovery/overview",
      "phase": "conceptualization",
      "sub_phase": "overall-concept",
      "folder": "01_project/",
      "hard_gates": [],
      "user_inputs": {
        "dialog": [
          {
            "id": "app_name",
            "label": "App Name",
            "type": "text",
            "required": true
          },
          {
            "id": "elevator_pitch",
            "label": "Elevator Pitch",
            "type": "textarea",
            "required": true
          },
          {
            "id": "target_audience",
            "label": "Target Audience",
            "type": "textarea",
            "required": true
          },
          {
            "id": "problem_statement",
            "label": "Problem Statement",
            "type": "textarea",
            "required": true
          },
          {
            "id": "complexity",
            "label": "App Complexity",
            "type": "select",
            "options": ["simple", "moderate", "complex", "enterprise"],
            "required": true
          },
          {
            "id": "research_depth",
            "label": "Research Depth",
            "type": "select",
            "options": ["skip", "light", "moderate", "deep"],
            "default": "moderate"
          }
        ],
        "files": ["01_project/brief.md"]
      },
      "description": "Elevator pitch, audience, problem, hero flow",
      "ui": {
        "start_questions": [
          "I have an app idea \u2014 help me write the brief",
          "What problem does my app solve?",
          "Who is the target audience?",
          "Describe the hero flow step by step"
        ],
        "scaffold_on_init": true
      }
    },
    {
      "id": "concept/experience/journeys",
      "name": "User Journeys",
      "skill": "concept/experience/journeys",
      "phase": "conceptualization",
      "sub_phase": "functionality",
      "folder": "02_journeys/",
      "hard_gates": ["01_project/brief.md", "01_project/goals.md"],
      "user_inputs": {
        "dialog": [],
        "files": ["02_journeys/stories.json"]
      },
      "description": "Map user journeys with personas, story maps (hero/vital/hygiene/backlog), and EARS acceptance criteria. Produces stories.json for the features skill."
    },
    {
      "id": "concept/experience/features",
      "name": "Features",
      "skill": "concept/experience/features",
      "phase": "conceptualization",
      "sub_phase": "functionality",
      "folder": "03_features/",
      "hard_gates": [
