        "files": []
      },
      "description": "Feature specs in numbered groups",
      "ui": {
        "start_questions": [
          "Generate feature specs from the project brief",
          "What are the core user workflows?",
          "Break features into numbered groups",
          "Add acceptance criteria to each feature"
        ],
        "impl_status_tracking": true,
        "scaffold_on_init": true
      }
    },
