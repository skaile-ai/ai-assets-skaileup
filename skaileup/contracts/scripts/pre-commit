#!/usr/bin/env bash
# pre-commit — catalog integrity hooks
#
# Install: cp skaileup/contracts/scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or use symlink: ln -s ../../skaileup/contracts/scripts/pre-commit .git/hooks/pre-commit
#
# Checks:
#   1. No SKILL.md files reference the old _grounding/general/ path
#   2. No SKILL.md files use deprecated user_inputs / reads_from / writes_to
#   3. Artifact registry consistency (when SKILL.md or artifacts.yaml staged)
#   4. Flow manifest consistency (when a *.flow.yaml is staged)

set -euo pipefail

FAILED=0

# 1. Stale grounding path check
if git diff --cached --name-only | grep -q "SKILL\.md$"; then
    CHANGED_SKILLS=$(git diff --cached --name-only | grep "SKILL\.md$")
    while IFS= read -r f; do
        if [ -f "$f" ] && grep -q "_grounding/general/" "$f"; then
            echo "ERROR: $f references deprecated _grounding/general/ (should be _grounding/research/)"
            FAILED=1
        fi
    done <<< "$CHANGED_SKILLS"
fi

# 2. Deprecated frontmatter field check
if git diff --cached --name-only | grep -q "SKILL\.md$"; then
    CHANGED_SKILLS=$(git diff --cached --name-only | grep "SKILL\.md$")
    while IFS= read -r f; do
        if [ -f "$f" ]; then
            if grep -qE "^\s+user_inputs\s*:" "$f"; then
                echo "ERROR: $f uses deprecated metadata.user_inputs — migrate to metadata.prerequisites"
                FAILED=1
            fi
            if grep -qE "^\s*reads_from\s*:" "$f"; then
                echo "ERROR: $f uses deprecated reads_from — migrate to metadata.prerequisites.reads"
                FAILED=1
            fi
            if grep -qE "^\s*writes_to\s*:" "$f"; then
                echo "ERROR: $f uses deprecated writes_to — migrate to metadata.prerequisites.produces"
                FAILED=1
            fi
        fi
    done <<< "$CHANGED_SKILLS"
fi

# 3. Artifact registry consistency
if git diff --cached --name-only | grep -qE "(SKILL\.md|contracts/artifacts\.yaml)$"; then
    if python3 -c "import yaml" 2>/dev/null; then
        if ! python3 skaileup/contracts/scripts/verify_artifacts.py | grep -q "0 errors"; then
            python3 skaileup/contracts/scripts/verify_artifacts.py | grep "^ERROR" || true
            echo "ERROR: artifact registry check failed (see skaileup/contracts/artifacts.yaml)"
            FAILED=1
        fi
    else
        echo "WARN: PyYAML not installed — skipping artifact registry check (CI still enforces it)"
    fi
fi

# 4. Flow manifest consistency — each flow's requires: must match its node graph
if git diff --cached --name-only | grep -qE "\.flow\.yaml$"; then
    if python3 -c "import yaml, jsonschema" 2>/dev/null; then
        if ! python3 skaileup/flows/_meta/verify_flows.py > /dev/null; then
            python3 skaileup/flows/_meta/verify_flows.py 2>&1 | grep "^ERROR" || true
            echo "ERROR: flow manifest check failed (see skaileup/flows/_meta/verify_flows.py)"
            FAILED=1
        fi
    else
        echo "WARN: PyYAML/jsonschema not installed — skipping flow manifest check (CI still enforces it)"
    fi
fi

if [ "$FAILED" -eq 1 ]; then
    echo ""
    echo "Pre-commit check failed. Fix the issues above before committing."
    exit 1
fi

exit 0
